{
  "compilerOptions": {
    "ignoreDeprecations": "6.0", // change later........
    "module": "es2022",
    "strict": true,
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "sourceMap": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": "src",
    "paths": {
      "@services/*": ["services/*"],
      "@controllers/*": ["controllers/*"],
      "@utils/*": ["utils/*"],
      "@models/*": ["models/*"],
      "@config/*": ["config/*"],
      "@queues/*": ["queues/*"],
      "@workers/*": ["workers/*"],
      "@schemas/*": ["schemas/*"],
      "@types/*": ["types/*"],
      "@routes/*": ["routes/*"],
      "@dal/*": ["dal/*"],
      "@cron/*": ["cron/*"]
    },
    "noImplicitAny": true,
    "noImplicitReturns": true
  },
  "include": ["src/**/*", "jest.config.js", "__tests__", "sandbox", "env.d.ts", "scripts"],
  "exclude": ["node_modules", "**/node_modules/*"]
}
